<!DOCTYPE html>
<html>
<head>
<title>QuestMystery Lab</title>
<style>
body {font-family: Arial; margin:0; background:#222; color:white;}
header {background:#000; padding:15px; text-align:center;}
.card {background:#333; padding:20px; margin:50px auto; width:300px; border-radius:10px; text-align:center;}
button {padding:10px; background:gold; border:none;}
</style>
</head>

<body>
<header><h1>🔍 QuestMystery Lab</h1></header>

<div class="card">
<button onclick="gen()">Generate Mystery</button>
<p id="out"></p>
</div>

<script>
function gen(){
let ideas=["Hidden treasure","School mystery","Secret cave"];
document.getElementById("out").innerText=
ideas[Math.floor(Math.random()*ideas.length)];
}
</script>

</body>
</html>
